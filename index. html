<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Đối kháng Hóa Học</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="start-container" id="startScreen">
        <h1>🔥 Đối Kháng Hóa Học 🔥</h1>
        <button class="btn" onclick="startGame()">🎮 BẮT ĐẦU TRẬN MỚI</button>
    </div>

    <div class="container" id="gameContainer">
        <h2>🎭 Đối thủ</h2>
        <div class="enemy" id="enemyCards"></div>

        <h2>🃏 Bộ bài của bạn</h2>
        <div class="player" id="playerCards"></div>

        <div class="logs" id="logs">📝 Chọn một lá bài của bạn, sau đó chọn một lá bài của đối thủ!</div>

        <button class="btn" id="restartBtn" onclick="restartGame()" style="display: none;">🔄 CHƠI LẠI</button>
    </div>

    <script src="reactions.js"></script>
    <script src="script.js"></script>
</body>
</html>
